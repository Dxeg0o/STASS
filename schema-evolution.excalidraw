    {"id":"ej_ti","type":"text","x":880,"y":20,"width":300,"height":20,"text":"EJEMPLO","fontSize":16,"fontFamily":1,"textAlign":"left","strokeColor":"#495057","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":71,"version":1,"isDeleted":false,"boundElements":null,"link":null,"locked":false,"groupIds":[]},
    {"id":"ej_t","type":"text","x":885,"y":48,"width":420,"height":474,"text":"1. DEFINIR WORKFLOW:\n  tipo_proceso: Plantacion, Cosecha, Lavado\n  workflow: \"Engorde Bulbos\"\n    paso 1: Plantacion\n    paso 2: Cosecha\n    paso 3: Lavado\n\n2. CREAR PROCESOS (instancias):\n  proceso: tipo=Plantacion, temp=\"2025\"\n    servicio: \"Plant. Pelchuquin\" usa_cajas:F\n    servicio: \"Plant. Los Lagos\" usa_cajas:F\n  proceso: tipo=Lavado, temp=\"2025\"\n    servicio: \"Lavado Planta\" usa_cajas:T\n\n3. ASIGNAR LOTES:\n  lote abc-123 → lote_servicio\n    → Plant. Pelchuquin (activo)\n  Luego:\n    cerrar Plant. Pelchuquin\n    → lote_servicio Lavado Planta (activo)\n      caja QR-001 → caja_lote_session\n      conteo → trigger → caja_stats\n\n4. HISTORIAL:\n  lote_servicio de abc-123:\n    Plant.Pelchuquin → proceso Plantacion\n    Lavado Planta → proceso Lavado\n  Workflow \"Engorde\" paso 1✓ 2? 3✓","fontSize":13,"fontFamily":3,"textAlign":"left","strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":72,"version":1,"isDeleted":false,"boundElements":null,"link":null,"locked":false,"groupIds":[],"containerId":"ej_b"},

    {"id":"re_b","type":"rectangle","x":870,"y":570,"width":440,"height":220,"strokeColor":"#1971c2","backgroundColor":"#e7f5ff","fillStyle":"solid","strokeWidth":2,"roughness":0,"opacity":100,"angle":0,"seed":75,"version":1,"isDeleted":false,"roundness":{"type":3},"boundElements":[],"link":null,"locked":false,"groupIds":[]},
    {"id":"re_ti","type":"text","x":880,"y":550,"width":200,"height":20,"text":"RESUMEN","fontSize":16,"fontFamily":1,"textAlign":"left","strokeColor":"#1971c2","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":76,"version":1,"isDeleted":false,"boundElements":null,"link":null,"locked":false,"groupIds":[]},
    {"id":"re_t","type":"text","x":885,"y":578,"width":420,"height":204,"text":"NUEVAS (8):\n  tipo_proceso, workflow_empresa, workflow_paso\n  proceso\n  lote_servicio (N:N, reemplaza lote.servicio_id)\n  caja, caja_lote_session, caja_stats\n\nMODIFICADAS:\n  servicio (+proceso_id, +usa_cajas, -orden)\n  conteo (+caja_lote_session_id nullable)\n  lote (-nombre, -servicio_id → lote_servicio)\n\nIGUAL: lote_session, lote_stats, ubicacion, etc","fontSize":13,"fontFamily":3,"textAlign":"left","strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"angle":0,"seed":77,"version":1,"isDeleted":false,"boundElements":null,"link":null,"locked":false,"groupIds":[],"containerId":"re_b"}
